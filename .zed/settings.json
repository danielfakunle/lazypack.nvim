{
  "lsp": {
    "lua-language-server": {
      "settings": {
        "Lua": {
          "runtime": {
            "version": "LuaJIT"
          },
          "workspace": {
            "checkThirdParty": false
          },
          "diagnostics": {
            "globals": [
              "vim",
              "describe",
              "it",
              "before_each",
              "after_each",
              "assert"
            ]
          },
          "hint": {
            "enable": true
          },
          "telemetry": {
            "enable": false
          }
        }
      }
    }
  }
}
